# Isolated PostgreSQL for era-hotel-pms only
# Host: localhost | Docker compose: postgres service
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/era_hotel_pms?schema=public"

# Redis — retry queue for outbound events
# Host: localhost | Docker compose: redis service
REDIS_URL="redis://localhost:6379"

# Outbound integration — Nafta: 1C bridge listener; ERA: central API gateway
EXTERNAL_INTEGRATION_URL="http://localhost:3000/api/integration/mock-receiver"
EXTERNAL_NIGHT_AUDIT_URL=""
EXTERNAL_INTEGRATION_TOKEN=""

# HTTP client for event dispatcher
EXTERNAL_HTTP_TIMEOUT_MS=10000
EXTERNAL_RETRY_MAX=3

# Outbound channel toggles (env fallback until Admin → Integration UI saved)
OUTBOUND_ENABLED=true
OUTBOUND_REALTIME_CHARGES=true
OUTBOUND_REALTIME_PAYMENTS=true
OUTBOUND_REALTIME_VOIDS=true
OUTBOUND_CHECKOUT_EVENT=true
OUTBOUND_NIGHT_AUDIT_EVENT=true

# Phase 2 — ERP inbound (E6 fiscal status callback)
ERP_INBOUND_WEBHOOK_SECRET="dev-erp-webhook-secret"
OUTBOUND_INVOICE_ISSUED=true
OUTBOUND_PAYMENT_FISCALIZED=true
OUTBOUND_CITY_LEDGER_SNAPSHOT=true
OUTBOUND_MASTER_DATA_SYNC=true

# Phase 2 — POS bridge (room charge from era-fb-pos or admin test)
POS_BRIDGE_SECRET="dev-pos-bridge-secret"
# PMS → fb-pos webhook on check-out (era-fb-pos URL; optional until FB-1)
FB_POS_WEBHOOK_URL="http://localhost:3200/api/webhooks/pms/reservation-lifecycle"
# UI link to era-fb-pos (nav opens in new tab)
NEXT_PUBLIC_FB_POS_URL="http://localhost:3200"

# Phase 2 — AZ tourism registry (mock when URL empty)
TOURISM_REGISTRY_ENABLED=false
TOURISM_REGISTRY_URL=""

# Phase 2 — stock consumption on POS room-charge with productSku
STOCK_CONSUMPTION_ENABLED=false

# Property code sent in every envelope (see doc/clone-spec/18-erp-integration.md)
HOTEL_PROPERTY_CODE="NAFTA-SANATORIUM-001"

# UI locale (en | ru | az) — cookie NEXT_LOCALE overrides after user choice
DEFAULT_LOCALE=en

# Auth (satellite-local RBAC)
AUTH_JWT_SECRET="change-me-to-a-long-random-secret-min-32-chars"
AUTH_COOKIE_NAME="era_session"

# ERA Core seat licensing (mock in dev)
ERA_CORE_LICENSING_URL="http://localhost:3000/api/integration/mock-licensing"
ERA_CORE_API_KEY=""
LICENSING_SEAT_LIMIT=10

# SSO from ERA Core (Financial_Auditor)
ERA_SSO_SHARED_SECRET="dev-sso-secret-change-in-production"

# Docker dev only — seed on container start
RUN_SEED=false
