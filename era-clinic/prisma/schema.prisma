generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  outlets   Outlet[]
}

enum LabOrderStatus {
  ORDERED
  COLLECTED
  IN_PROGRESS
  RESULT_READY
  PUBLISHED
  COMPLETED
}

model Outlet {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  preset    String?
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  @@unique([tenantId, code])
}

model PatientRef {
  id           String         @id @default(cuid())
  refCode      String         @unique
  fullName     String
  phone        String?
  globalPersonId String?
  appointments Appointment[]
  visits       Visit[]
  labOrders    LabOrder[]
  episodes     ClinicalEpisode[]
  createdAt    DateTime       @default(now())
}

model Practitioner {
  id           String        @id @default(cuid())
  code         String        @unique
  fullName     String
  appointments Appointment[]
  visits       Visit[]
}

model Appointment {
  id             String       @id @default(cuid())
  patientRefId   String
  practitionerId String
  scheduledAt    DateTime
  status         String       @default("SCHEDULED")
  reminderSentAt DateTime?
  patientRef     PatientRef   @relation(fields: [patientRefId], references: [id])
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id])
  visit          Visit?
  createdAt      DateTime     @default(now())
}

model Visit {
  id             String               @id @default(cuid())
  appointmentId  String?              @unique
  patientRefId   String
  practitionerId String
  status         String               @default("IN_PROGRESS")
  amountNet      Decimal              @default(0) @db.Decimal(12, 2)
  completedAt    DateTime?
  patientRef     PatientRef           @relation(fields: [patientRefId], references: [id])
  practitioner   Practitioner         @relation(fields: [practitionerId], references: [id])
  appointment    Appointment?         @relation(fields: [appointmentId], references: [id])
  serviceLines   VisitServiceLine[]
  labOrders      LabOrder[]
  discountAudits VisitDiscountAudit[]
  createdAt      DateTime             @default(now())
}

model VisitServiceLine {
  id          String  @id @default(cuid())
  visitId     String
  serviceCode String
  description String
  amount      Decimal @db.Decimal(12, 2)
  visit       Visit   @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
}

model LabOrder {
  id           String         @id @default(cuid())
  patientRefId String
  visitId      String?
  clinicalEpisodeId String?
  testCode     String
  status       LabOrderStatus @default(ORDERED)
  amountNet    Decimal        @default(0) @db.Decimal(12, 2)
  collectedAt  DateTime?
  resultJson   String?
  publishedAt  DateTime?
  completedAt  DateTime?
  patientRef   PatientRef     @relation(fields: [patientRefId], references: [id])
  visit        Visit?         @relation(fields: [visitId], references: [id])
  episode      ClinicalEpisode? @relation(fields: [clinicalEpisodeId], references: [id])
  createdAt    DateTime       @default(now())

  @@index([patientRefId, status])
  @@index([visitId])
  @@index([clinicalEpisodeId])
}

model ClinicalEpisode {
  id             String              @id @default(cuid())
  patientRefId   String?
  patientRef     PatientRef?         @relation(fields: [patientRefId], references: [id])
  globalPersonId String?
  hotelStayId    String?
  reservationId  String?
  organizationId String
  status         String              @default("OPEN")
  openedAt       DateTime            @default(now())
  closedAt       DateTime?
  complaints     ClinicalComplaint[]
  diagnoses      ClinicalDiagnosis[]
  labOrders      LabOrder[]

  @@index([reservationId])
  @@index([organizationId, status])
}

model ClinicalComplaint {
  id         String          @id @default(cuid())
  episodeId  String
  episode    ClinicalEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  text       String
  recordedAt DateTime        @default(now())

  @@index([episodeId])
}

model ClinicalDiagnosis {
  id          String          @id @default(cuid())
  episodeId   String
  episode     ClinicalEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  icdCode     String?
  description String
  recordedAt  DateTime        @default(now())

  @@index([episodeId])
}

model VisitDiscountAudit {
  id         String   @id @default(cuid())
  visitId    String
  percent    Decimal  @db.Decimal(5, 2)
  approvedBy String
  reason     String
  visit      Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([visitId])
}

model Role {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  permissionsJson String   @default("[]")
  users           User[]
}

model User {
  id              String    @id @default(cuid())
  login           String    @unique
  email           String?
  fullName        String
  passwordHash    String
  roleId          String
  role            Role      @relation(fields: [roleId], references: [id])
  status          String    @default("ACTIVE")
  isCrossSystem   Boolean   @default(false) @map("is_cross_system")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
}
