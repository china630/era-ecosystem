generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  outlets   Outlet[]
}

enum TripStatus {
  PLANNED
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
}

model Outlet {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  preset    String?
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  @@unique([tenantId, code])
}

model Vehicle {
  id                   String    @id @default(cuid())
  plate                String    @unique
  model                String?
  insuranceExpiresAt   DateTime?
  inspectionExpiresAt  DateTime?
  permitExpiresAt      DateTime?
  trips                Trip[]
  createdAt            DateTime  @default(now())
}

model Trip {
  id            String     @id @default(cuid())
  vehicleId     String
  status        TripStatus @default(PLANNED)
  routeCode     String?
  freightAmount Decimal    @default(0) @db.Decimal(12, 2)
  startedAt     DateTime?
  completedAt   DateTime?
  podCapturedAt   DateTime?
  podRecipient    String?
  podNotes        String?
  podPhotoUrl     String?
  podSignatureUrl String?
  waybillNumber   String?
  waybillIssuedAt DateTime?
  fuelLiters      Decimal?   @db.Decimal(10, 2)
  fuelCost      Decimal?   @db.Decimal(12, 2)
  vehicle       Vehicle    @relation(fields: [vehicleId], references: [id])
  points        TripPoint[]
  trackingToken String?    @unique
  createdAt     DateTime   @default(now())

  @@index([vehicleId, status])
}

model TripPoint {
  id            String    @id @default(cuid())
  tripId        String
  sequence      Int
  addressLabel  String
  status        String    @default("PENDING")
  latitude      Decimal?  @db.Decimal(10, 6)
  longitude     Decimal?  @db.Decimal(10, 6)
  podRecipient  String?
  podCapturedAt DateTime?
  trip          Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@unique([tripId, sequence])
  @@index([tripId, status])
}

model Role {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  permissionsJson String   @default("[]")
  users           User[]
}

model User {
  id              String    @id @default(cuid())
  login           String    @unique
  email           String?
  fullName        String
  passwordHash    String
  roleId          String
  role            Role      @relation(fields: [roleId], references: [id])
  status          String    @default("ACTIVE")
  isCrossSystem   Boolean   @default(false) @map("is_cross_system")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
}
