# ERA Ecosystem — root Docker Compose
# cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=era
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=era
POSTGRES_PUBLISH_PORT=5432

ORCHESTRATOR_DB=era_orchestrator
FINANCE_DB=era_finance
HOTEL_DB=era_hotel_pms
FB_POS_DB=era_fb_pos
RETAIL_POS_DB=era_retail_pos
LOGISTICS_DB=era_logistics
CONSTRUCTION_DB=era_construction
CRM_FIELD_DB=era_crm_field
AUTO_STO_DB=era_auto_sto
WHOLESALE_DB=era_wholesale
CLINIC_DB=era_clinic

# --- Redis ---
REDIS_PUBLISH_PORT=6379

# --- Control plane ↔ data plane (internal) ---
CONTROL_PLANE_SERVICE_TOKEN=dev-control-plane-token

# --- SSO (HS256 phase A; RS256/JWKS phase A+) ---
ERA_JWT_SECRET=change-me-shared-hs256-secret-min-32-chars
ERA_JWT_ISSUER=era-365-orchestrator
ERA_JWT_AUDIENCE_FINANCE=era-finance-core
ERA_JWT_ACCESS_EXPIRES=12h
ERA_SSO_SHARED_SECRET=change-me-sso-hmac-secret
# finance-core: legacy | control-plane
ERA_AUTH_MODE=legacy

# --- Satellite event bus (orchestrator → BullMQ → finance-core) ---
SATELLITE_EVENT_SERVICE_TOKEN=dev-satellite-event-token
SATELLITE_EVENT_REDIS_URL=redis://127.0.0.1:6379/0
ERA_EVENT_GATEWAY_MODE=legacy
ORCHESTRATOR_EVENT_URL=http://orchestrator:4100
ERA_SATELLITE_ORGANIZATION_ID=
SATELLITE_DEFAULT_COUNTERPARTY_ID=
SATELLITE_GL_RECEIVABLE=201
SATELLITE_GL_REVENUE=601
SATELLITE_GL_WIP=111

# --- Industry satellite deep links (Finance web) ---
NEXT_PUBLIC_SATELLITE_RETAIL_URL=http://retail.era.az
NEXT_PUBLIC_SATELLITE_LOGISTICS_URL=http://logistics.era.az
NEXT_PUBLIC_SATELLITE_CONSTRUCTION_URL=http://construction.era.az
NEXT_PUBLIC_SATELLITE_CRM_URL=http://crm.era.az
NEXT_PUBLIC_SATELLITE_AUTO_URL=http://auto.era.az
NEXT_PUBLIC_SATELLITE_CLINIC_URL=http://clinic.era.az
NEXT_PUBLIC_SATELLITE_WHOLESALE_URL=http://wholesale.era.az

# --- Hotel PMS ↔ F&B POS bridge ---
POS_BRIDGE_SECRET=dev-pos-bridge-secret
FB_POS_WEBHOOK_SECRET=dev-fb-pos-webhook-secret
AUTH_JWT_SECRET=change-me-min-32-chars-for-hotel-pms

# --- Local hosts file (optional) ---
# 127.0.0.1 app.era.az api.era.az hotel.era.az pos.era.az retail.era.az logistics.era.az construction.era.az crm.era.az auto.era.az wholesale.era.az clinic.era.az
