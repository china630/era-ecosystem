generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  outlets   Outlet[]
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum LeadChannel {
  whatsapp
  instagram
  visit
  phone
  other
}

model Outlet {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  preset    String?
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  @@unique([tenantId, code])
}

model Lead {
  id              String             @id @default(cuid())
  stage           LeadStage          @default(NEW)
  title           String
  contactRef      String
  channel         LeadChannel        @default(other)
  estimatedAmount Decimal?           @db.Decimal(12, 2)
  counterpartyId  String?
  ownerId         String?
  nextContactAt   DateTime?
  score           Int       @default(0)
  scoreUpdatedAt  DateTime?
  owner           User?              @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  visits          Visit[]
  stageHistory    LeadStageHistory[]
  inboxThreads    InboxThread[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  convertedAt     DateTime?

  @@index([ownerId])
}

model LeadStageHistory {
  id        String     @id @default(cuid())
  leadId    String
  fromStage LeadStage?
  toStage   LeadStage
  changedAt DateTime   @default(now())
  lead      Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model Visit {
  id           String   @id @default(cuid())
  leadId       String
  notes        String?
  addressLabel String?
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  visitedAt    DateTime @default(now())
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model Role {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  permissionsJson String   @default("[]")
  users           User[]
}

model User {
  id              String    @id @default(cuid())
  login           String    @unique
  email           String?
  fullName        String
  passwordHash    String
  roleId          String
  role            Role      @relation(fields: [roleId], references: [id])
  status          String    @default("ACTIVE")
  isCrossSystem   Boolean   @default(false) @map("is_cross_system")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  ownedLeads      Lead[]
}

enum InboxChannel {
  whatsapp
  instagram
}

model InboxThread {
  id            String       @id @default(cuid())
  channel       InboxChannel
  externalRef   String
  leadId        String?
  preview       String?
  lastMessageAt DateTime     @default(now())
  lead          Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())

  @@index([leadId])
  @@index([lastMessageAt])
}
