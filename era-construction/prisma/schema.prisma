generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  outlets   Outlet[]
}

model Outlet {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  preset    String?
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  @@unique([tenantId, code])
}

model Project {
  id                   String                @id @default(cuid())
  code                 String                @unique
  name                 String
  progressActs         ProgressAct[]
  materialRequisitions MaterialRequisition[]
  boqLines             BoqLine[]
  createdAt            DateTime              @default(now())
}

model BoqLine {
  id               String   @id @default(cuid())
  projectId        String
  itemCode         String
  description      String
  plannedQty       Decimal  @db.Decimal(12, 3)
  plannedAmountNet Decimal  @default(0) @db.Decimal(12, 2)
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@unique([projectId, itemCode])
  @@index([projectId])
}

model MaterialRequisition {
  id          String   @id @default(cuid())
  projectId   String
  itemCode    String
  description String
  qty         Decimal  @db.Decimal(12, 3)
  status      String   @default("DRAFT")
  project     Project  @relation(fields: [projectId], references: [id])
  createdAt   DateTime @default(now())

  @@index([projectId, status])
}

model ProgressAct {
  id         String    @id @default(cuid())
  projectId  String
  periodKey  String?
  amountNet  Decimal   @db.Decimal(12, 2)
  status     String    @default("DRAFT")
  approvedAt DateTime?
  project    Project   @relation(fields: [projectId], references: [id])
  createdAt  DateTime  @default(now())

  @@index([projectId])
}

model Role {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  permissionsJson String   @default("[]")
  users           User[]
}

model User {
  id              String    @id @default(cuid())
  login           String    @unique
  email           String?
  fullName        String
  passwordHash    String
  roleId          String
  role            Role      @relation(fields: [roleId], references: [id])
  status          String    @default("ACTIVE")
  isCrossSystem   Boolean   @default(false) @map("is_cross_system")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
}
