# Used only for: npx dotenv-cli -e docker/migrate-to-stack.env -- npm run db:migrate:deploy -w @erafinance/database
# Host must reach Postgres published by docker-compose.prod.yml (see docker/stack.local.env POSTGRES_* and *_PUBLISH_PORT).
DATABASE_URL=postgresql://erafinance:erafinance_local_docker_only@127.0.0.1:55432/erafinance?schema=public
