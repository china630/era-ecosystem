# Example for local full stack: copy to stack.local.env and adjust.
#   copy docker\\stack.local.env.example docker\\stack.local.env
#
# Run from repo root:
#   docker compose --env-file docker/stack.local.env -f docker-compose.prod.yml build
#   docker compose --env-file docker/stack.local.env -f docker-compose.prod.yml up -d
#
# See docker/stack.local.env (gitignored in your clone if you prefer secrets local-only).

COMPOSE_PROJECT_NAME=erafinance_erp
POSTGRES_USER=erafinance
POSTGRES_PASSWORD=change_me
POSTGRES_DB=erafinance
POSTGRES_PUBLISH_PORT=55432
REDIS_PUBLISH_PORT=56379
API_PORT=4000
API_PUBLISH_PORT=14000
PORT=13000
REDIS_URL=redis://redis:6379
JWT_SECRET=replace-with-32-plus-char-secret
JWT_REFRESH_SECRET=replace-with-32-plus-char-secret
NEXT_PUBLIC_API_URL=http://127.0.0.1:14000
CORS_ORIGINS=http://127.0.0.1:13000,http://localhost:13000
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=/var/lib/erafinance/storage
ERAFINANCE_STORAGE_HOST_PATH=D:/DockerData/erafinance_erp/storage
