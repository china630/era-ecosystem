{
  "name": "erafinance-erp",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"npm run dev:api\" \"wait-on tcp:127.0.0.1:4000 && npm run dev:web\"",
    "dev:api": "dotenv -e .env -o -- npm run start:dev -w @erafinance/api",
    "dev:web": "dotenv -e .env -o -- npm run dev -w @erafinance/web",
    "dev:web:clean": "dotenv -e .env -o -- npm run dev:clean -w @erafinance/web",
    "dev:ext": "dotenv -e .env -o -- npm run dev -w @erafinance/extension",
    "restart:web": "npm run stop:next && dotenv -e .env -o -- npm run dev:clean -w @erafinance/web",
    "restart:api": "npm run stop:api && dotenv -e .env -o -- npm run start:dev -w @erafinance/api",
    "stop:next": "npx kill-port 3000",
    "stop:api": "npx kill-port 4000",
    "build": "npm run i18n:audit && npm run build -w @erafinance/database && npm run build -w @erafinance/api-contracts && npm run build -w @erafinance/api && npm run build -w @erafinance/web",
    "build:ext": "dotenv -e .env -o -- npm run build -w @erafinance/extension",
    "db:generate": "npm run db:generate -w @erafinance/database",
    "db:migrate": "npm run db:migrate -w @erafinance/database",
    "db:migrate:dev": "npm run db:migrate:dev -w @erafinance/database",
    "db:ensure-trade-pro-pricing": "npm run db:ensure-trade-pro-pricing -w @erafinance/database",
    "db:seed-customs-tariffs": "npm run db:seed-customs-tariffs -w @erafinance/database",
    "db:parse-az-customs-md": "npm run db:parse-az-customs-md -w @erafinance/database",
    "db:import-customs-tariff-json": "npm run db:import-customs-tariff-json -w @erafinance/database",
    "db:first-fill:customs-from-act": "npx dotenv-cli -e .env -- npm run db:migrate && npm run db:parse-az-customs-md && npx dotenv-cli -e .env -- npx tsx packages/database/scripts/import-customs-tariff-from-json.ts packages/database/prisma/catalog/trade/customs-tariff-rates.json --effective-from=2025-01-01 --notes-prefix=source=parsed-az-customs-act_act=e-qanun-37035",
    "db:migrate:deploy": "npm run db:migrate:deploy -w @erafinance/database",
    "db:migrate:resolve-squash-rolled-back": "dotenv -e .env -o -- npm exec -w @erafinance/database -- prisma migrate resolve --rolled-back 20260520120000_squashed_schema",
    "db:migrate:resolve-squash-applied": "dotenv -e .env -o -- npm exec -w @erafinance/database -- prisma migrate resolve --applied 20260520120000_squashed_schema",
    "db:migrate:clear-squash-row": "dotenv -e .env -o -- npm run db:migrate:clear-squash-row -w @erafinance/database",
    "db:migrate:reset-public-dev": "dotenv -e .env -o -- npm run db:migrate:reset-public-dev -w @erafinance/database",
    "db:bootstrap-local": "dotenv -e .env -o -- npm run db:migrate -w @erafinance/database && dotenv -e .env -o -- npm run db:seed && dotenv -e .env -o -- npm run db:sync-i18n -w @erafinance/database",
    "db:migrate:reset": "npm run db:migrate:reset -w @erafinance/database",
    "db:push": "npm run db:push -w @erafinance/database",
    "db:execute": "npm exec -w @erafinance/database prisma db execute --",
    "db:prisma": "npm exec -w @erafinance/database prisma --",
    "db:seed": "npm run db:seed -w @erafinance/database",
    "db:seed:verify": "npm run db:seed:verify -w @erafinance/database",
    "db:seed:core": "npm run db:seed:core -w @erafinance/database",
    "db:seed:national": "dotenv -e .env -o -- npm run db:seed:national -w @erafinance/database",
    "validate:posting-roles": "npm exec -w @erafinance/database -- tsx prisma/scripts/validate-posting-roles.ts",
    "db:seed:hr": "npm run db:seed:hr -w @erafinance/database",
    "db:seed:trade": "npm run db:seed:trade -w @erafinance/database",
    "db:seed:geo": "npm run db:seed:geo -w @erafinance/database",
    "db:seed:bank": "npm run db:seed:bank -w @erafinance/database",
    "db:seed:placeholders": "npm run db:seed:placeholders -w @erafinance/database",
    "db:audit-currency-codes": "npm run db:audit-currency-codes -w @erafinance/database",
    "db:seed:demo": "cross-env SEED_DEMO_ORG=1 npm run db:seed -w @erafinance/database",
    "db:seed:showcase": "npm run db:seed:demo && dotenv -e .env -o -- npm run seed:local -w @erafinance/api",
    "db:import-banks-md": "dotenv -e .env -o -- npm run db:import-banks-md -w @erafinance/database --",
    "db:import-banks-md:dry": "npm run db:import-banks-md:dry -w @erafinance/database --",
    "db:gen:banks-branches-seed": "npm run db:gen:banks-branches-seed -w @erafinance/database",
    "db:migrate:org-tax-cipher": "dotenv -e .env -o -- npm run db:migrate:org-tax-cipher -w @erafinance/database",
    "db:migrate:pii-stage3": "dotenv -e .env -o -- npm run db:migrate:pii-stage3 -w @erafinance/database",
    "db:nullify:pii-plaintext:phase1": "dotenv -e .env -o -- npm run db:nullify:pii-plaintext:phase1 -w @erafinance/database",
    "db:nullify:pii-plaintext:phase2": "dotenv -e .env -o -- npm run db:nullify:pii-plaintext:phase2 -w @erafinance/database",
    "db:audit:pii-cutover": "dotenv -e .env -o -- npm run db:audit:pii-cutover -w @erafinance/database",
    "db:audit:pii-plaintext": "dotenv -e .env -o -- npm run db:audit:pii-plaintext -w @erafinance/database",
    "db:assert:pii-plaintext-zero": "dotenv -e .env -o -- npm run db:assert:pii-plaintext-zero -w @erafinance/database",
    "db:dev-bootstrap": "npm run db:seed:demo && npm run db:sync-i18n:prune -w @erafinance/database && npm run db:prod-init -w @erafinance/database",
    "db:setup": "npm run db:migrate:deploy && npm run db:dev-bootstrap",
    "db:ifrs-demo-map": "npm run db:ifrs-demo-map -w @erafinance/database",
    "db:studio": "npm run db:studio -w @erafinance/database",
    "db:sync-i18n": "npm run db:sync-i18n -w @erafinance/database",
    "db:sync-i18n:prune": "npm run db:sync-i18n:prune -w @erafinance/database",
    "db:audit-i18n-overrides": "npm run db:audit-i18n-overrides -w @erafinance/database",
    "db:audit-i18n-overrides:fix": "npm run db:audit-i18n-overrides:fix -w @erafinance/database",
    "db:dump-to-prod": "npm run docker-init:export -w @erafinance/database",
    "db:wipe-tenant": "npx tsx packages/database/prisma/scripts/ops/platform/wipe-tenant-data.ts",
    "db:seed:tivi": "npm run db:seed:tivi -w @erafinance/database",
    "db:prod-init": "npm run db:migrate:deploy && npm run db:seed && npm run db:sync-i18n:prune -w @erafinance/database && npm run db:prod-init -w @erafinance/database",
    "db:deploy": "dotenv -e .env -o -- npm run db:migrate:deploy -w @erafinance/database && dotenv -e .env -o -- npm run db:sync-i18n:prune -w @erafinance/database",
    "db:apply-template:ifrs": "npm run db:apply-template:ifrs -w @erafinance/database",
    "docker-init:export": "npm run docker-init:export -w @erafinance/database",
    "docker-init:super-admin-hash": "npm run docker-init:super-admin-hash -w @erafinance/database",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:stack:build": "docker compose --env-file docker/stack.local.env -f docker-compose.prod.yml build",
    "docker:stack:up": "docker compose --env-file docker/stack.local.env -f docker-compose.prod.yml up -d",
    "docker:stack:down": "docker compose --env-file docker/stack.local.env -f docker-compose.prod.yml down",
    "i18n:audit": "npx tsx scripts/i18n-audit.ts",
    "i18n:catalog": "npm run gen:i18n-catalog -w @erafinance/api",
    "platform:billing-reconcile": "dotenv -e .env -o -- npx tsx scripts/billing-reconciliation.ts",
    "platform:dr-validate": "dotenv -e .env -o -- npx tsx scripts/dr-drill-validate.ts",
    "platform:dr-tenant-rollback": "dotenv -e .env -o -- npx tsx scripts/dr-drill-tenant-rollback.ts",
    "audit:verify": "dotenv -e .env -o -- npm run audit:verify -w @erafinance/api",
    "screenshots:erp": "dotenv -e .env -o -- npm run capture --prefix tools/playwright-screenshots --"
  },
  "dependencies": {
    "cross-env": "^10.1.0"
  },
  "devDependencies": {
    "@erafinance/i18n": "*",
    "concurrently": "^9.1.2",
    "dotenv-cli": "^8.0.0",
    "kill-port": "^2.0.1",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "@erafinance/docs": {
      "react": "18.3.1",
      "react-dom": "18.3.1"
    }
  }
}
