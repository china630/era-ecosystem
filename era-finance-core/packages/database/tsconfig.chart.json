{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "prisma",
    "module": "commonjs",
    "target": "ES2022",
    "declaration": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": [
    "prisma/lib/chart/chart-seed.ts",
    "prisma/lib/core/pricing-module-keys.ts",
    "prisma/lib/core/pricing-module-seed.ts",
    "prisma/lib/core/pricing-bundle-seed.ts",
    "prisma/lib/core/ensure-currencies-seed.ts",
    "prisma/lib/org/legal-form-kind.mapper.ts",
    "prisma/lib/posting/posting-role.ts",
    "prisma/lib/posting/posting-seed.ts"
  ]
}
