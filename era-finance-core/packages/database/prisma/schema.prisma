// --- Platform recovery: dispute, dual approval, snapshots, rollback (PRD §7.13 / TZ §21) ---

enum DualApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  EXECUTED
}

enum DisputeStatus {
  EVIDENCE_REQUIRED
  EVIDENCE_REVIEW
  INCUMBENT_NOTIFIED
  COOLDOWN
  APPROVED
  REJECTED
  EXECUTED
  REVERTED
}

enum DisputeSeverity {
  SOFT
  HARD
}

enum SecurityMode {
  NORMAL
  DISPUTE
  POST_TRANSFER_LOCK
  ROLLBACK_IN_PROGRESS
  HARD_BLOCK_PLATFORM
}

enum TenantRollbackStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  ABORTED
}

model DualApprovalRequest {
  id                String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  purpose           String
  payload           Json               @default("{}")
  requesterId       String             @map("requester_id") @db.Uuid
  approverIds       String[]           @default([]) @map("approver_ids") @db.Uuid
  status            DualApprovalStatus @default(PENDING)
  expiresAt         DateTime           @map("expires_at") @db.Timestamptz(6)
  executedAt        DateTime?          @map("executed_at") @db.Timestamptz(6)
  createdAt         DateTime           @default(now()) @map("created_at")
  requester         User               @relation("DualApprovalRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  ownershipDisputes OwnershipDispute[]

  @@index([status, expiresAt])
  @@map("dual_approval_requests")
}

model OwnershipDispute {
  id                     String                      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId         String                      @map("organization_id") @db.Uuid
  claimantUserId         String                      @map("claimant_user_id") @db.Uuid
  incumbentUserId        String                      @map("incumbent_user_id") @db.Uuid
  status                 DisputeStatus               @default(EVIDENCE_REQUIRED)
  severity               DisputeSeverity             @default(SOFT)
  evidenceKeys           String[]                    @default([]) @map("evidence_keys")
  verifiedAgainst        Json?                       @map("verified_against")
  cooldownEndsAt         DateTime?                   @map("cooldown_ends_at") @db.Timestamptz(6)
  approvalRequestId      String?                     @map("approval_request_id") @db.Uuid
  legalCaseRef           String?                     @map("legal_case_ref")
  signedCertificateKey   String?                     @map("signed_certificate_key")
  counterClaimNote       String?                     @map("counter_claim_note")
  createdAt              DateTime                    @default(now()) @map("created_at")
  executedAt             DateTime?                   @map("executed_at") @db.Timestamptz(6)
  organization           Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  claimant               User                        @relation("DisputeClaimant", fields: [claimantUserId], references: [id], onDelete: Cascade)
  incumbent              User                        @relation("DisputeIncumbent", fields: [incumbentUserId], references: [id], onDelete: Cascade)
  approvalRequest        DualApprovalRequest?        @relation(fields: [approvalRequestId], references: [id], onDelete: SetNull)
  activeInSecurityStates OrganizationSecurityState[] @relation("ActiveDispute")

  @@index([organizationId, status])
  @@map("ownership_disputes")
}

model OrganizationSecurityState {
  organizationId  String            @id @map("organization_id") @db.Uuid
  mode            SecurityMode      @default(NORMAL)
  lockUntil       DateTime?         @map("lock_until") @db.Timestamptz(6)
  activeDisputeId String?           @map("active_dispute_id") @db.Uuid
  updatedAt       DateTime          @updatedAt @map("updated_at")
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activeDispute   OwnershipDispute? @relation("ActiveDispute", fields: [activeDisputeId], references: [id], onDelete: SetNull)

  @@map("organization_security_states")
}

model OrganizationDataSnapshot {
  id                String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId    String                 @map("organization_id") @db.Uuid
  reason            String
  s3Key             String                 @map("s3_key")
  sha256            String                 @db.VarChar(64)
  sizeBytes         BigInt                 @map("size_bytes")
  takenAt           DateTime               @default(now()) @map("taken_at") @db.Timestamptz(6)
  expiresAt         DateTime               @map("expires_at") @db.Timestamptz(6)
  triggeredByUserId String?                @map("triggered_by_user_id") @db.Uuid
  organization      Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  triggeredBy       User?                  @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)
  rollbackRecords   TenantRollbackRecord[]

  @@index([organizationId, takenAt])
  @@map("organization_data_snapshots")
}

model TenantRollbackRecord {
  id             String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String                   @map("organization_id") @db.Uuid
  snapshotId     String                   @map("snapshot_id") @db.Uuid
  status         TenantRollbackStatus     @default(PENDING)
  progressJson   Json?                    @map("progress_json")
  errorMessage   String?                  @map("error_message")
  createdAt      DateTime                 @default(now()) @map("created_at")
  completedAt    DateTime?                @map("completed_at") @db.Timestamptz(6)
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  snapshot       OrganizationDataSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@map("tenant_rollback_records")
}

