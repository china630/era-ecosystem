/// Usage meter audit row (Phase 16).
model UsageMeterEvent {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  actionType     String   @map("action_type") @db.VarChar(64)
  quantity       Int      @default(1)
  unitCostAzn    Decimal  @map("unit_cost_azn") @db.Decimal(12, 4)
  balanceAfter   Decimal  @map("balance_after") @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@map("usage_meter_events")
}

