/// *
///  * История ЭЦП (ASAN/SİMA, публичная верификация по id записи).
model DigitalSignatureLog {
  id                    String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId        String                 @map("organization_id") @db.Uuid
  /// *
  ///    * INVOICE: invoice.id; RECONCILIATION_ACT: детерминированный UUID периода (см. reconciliationDocumentUuid).
  documentId            String                 @map("document_id") @db.Uuid
  certificateThumbprint String?                @map("certificate_thumbprint")
  signedAt              DateTime?              @map("signed_at")
  provider              SignatureProvider      @map("provider")
  status                DigitalSignatureStatus @default(PENDING_MOBILE) @map("status")
  certificateSubject    String?                @map("certificate_subject")
  certificateIssuer     String?                @map("certificate_issuer")
  pendingStartedAt      DateTime?              @map("pending_started_at")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  documentKind          SignedDocumentKind     @default(INVOICE) @map("document_kind")
  /// *
  ///    * SHA-256 финального PDF (hex), после генерации файла
  contentHashSha256     String?                @map("content_hash_sha256") @db.VarChar(64)
  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, signedAt])
  @@index([organizationId, documentId])
  @@index([organizationId, status])
  @@map("digital_signature_logs")
}

