  deletedReason          String?              @map("deleted_reason")

  @@index([organizationId])
  @@index([organizationId, warehouseId, date], map: "inventory_audits_org_wh_date_idx")
  @@index([organizationId, deletedAt], map: "inventory_audits_org_deleted_at_idx")
  @@index([organizationId, warehouseId, status], map: "inventory_audits_org_wh_status_idx")
  @@map("inventory_audits")
}

