model Transaction {
  id                           String                        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId               String                        @map("organization_id") @db.Uuid
  date                         DateTime                      @db.Date
  reference                    String?
  description                  String?
  createdAt                    DateTime                      @default(now()) @map("created_at")
  updatedAt                    DateTime                      @updatedAt @map("updated_at")
  /// *
  ///    * true — курс/суммы в документе зафиксированы (подтверждено бухгалтерией);
  ///    * false — «плавающий» курс до подтверждения.
  isFinal                      Boolean                       @default(false) @map("is_final")
  /// *
  ///    * Закрытый период: транзакция не должна корректироваться задним числом
  isLocked                     Boolean                       @default(false) @map("is_locked")
  counterpartyId               String?                       @map("counterparty_id") @db.Uuid
  /// Аналитика ЦФО: расходы/прочие проводки, привязанные к департаменту.
  departmentId                 String?                       @map("department_id") @db.Uuid
  /// Snapshot for purchase invoices (line-level goods/services payload for downstream documents).
  purchaseSnapshot             Json?                         @map("purchase_snapshot")
  /// Snapshot for sales recognition (goods lines + invoiceId basis for shipment flows).
  salesSnapshot                Json?                         @map("sales_snapshot")
  advanceReportsPosted         AdvanceReport?                @relation("AdvanceReportPostedTx")
  cashOrdersLinked             CashOrder[]                   @relation("CashOrderLinkedTx")
  cashOrdersPosted             CashOrder[]                   @relation("CashOrderPostedTx")
  fixedAssetDepreciationMonths FixedAssetDepreciationMonth[]
  invoicePayments              InvoicePayment[]
  paymentAllocations           PaymentAllocation[]
  journalEntries               JournalEntry[]
  payrollRuns                  PayrollRun[]
  counterparty                 Counterparty?                 @relation(fields: [counterpartyId], references: [id])
  department                   Department?                   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  organization                 Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customsDeclarations          CustomsDeclaration[]
  inventoryAuditsPosted        InventoryAudit[]         @relation("InventoryAuditPosting")
  prepaidSchedulesPosted       PrepaidExpenseSchedule[]
  manufacturingReleasesFg      ManufacturingRelease[]   @relation("MfgReleaseFgTransaction")
  manufacturingOrdersWip       ManufacturingOrder[]     @relation("MfgOrderWipTransaction")
  overheadAllocationsRelease   OverheadAllocation[]     @relation("OverheadAllocReleaseTransaction")

  @@index([organizationId, date])
  @@index([organizationId, isFinal, date], map: "transactions_org_status_period_idx")
  @@index([counterpartyId])
  @@index([organizationId, createdAt])
  @@index([organizationId, date, isLocked])
  @@index([departmentId])
  @@map("transactions")
}

model JournalEntry {
