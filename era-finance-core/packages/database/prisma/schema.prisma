/// *
///  * Подписка организации (1:1). Slugs модулей: production, ifrs, banking_pro и др.; v8.1 — customConfig.modules (конструктор).
model OrganizationSubscription {
  id                      String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId          String     @unique @map("organization_id") @db.Uuid
  currentTier             TariffTier @default(TIER_0) @map("current_tier")
  isTrial                 Boolean    @default(true) @map("is_trial")
  trialExpiresAt          DateTime?  @map("trial_expires_at") @db.Timestamptz(6)
  activatedPremiumModules String[]   @default([]) @map("activated_premium_modules")
  billingPeriodKey        String?    @map("billing_period_key") @db.VarChar(7)
  expiresAt               DateTime?  @map("expires_at") @db.Timestamptz(6)
  activeModules           String[]   @default([]) @map("active_modules")
  createdAt               DateTime   @default(now()) @map("created_at")
  updatedAt               DateTime   @updatedAt @map("updated_at")
  /// *
  ///    * Принудительная блокировка доступа (супер-админ).
  isBlocked      Boolean          @default(false) @map("is_blocked")
  /// *
  ///    * Конструктор тарифа (v8.1): JSON с полями `modules` (массив slug), опционально `preset`, `quotas`,
  ///    * `trialPackageId` (UUID PricingBundle), `trialQuotas` (копия/override квот на время trial).
  ///    * При непустом `modules` гейтинг модулей в первую очередь по этому массиву (см. TZ §14).
  customConfig   Json?            @map("custom_config")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_subscriptions")
}

