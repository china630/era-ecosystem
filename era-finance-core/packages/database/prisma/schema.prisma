// Finance data plane schema. Control-plane models (billing, subscription, RBAC)
// are owned by era-365-orchestrator (@era365/database). See CONTROL_PLANE_BOUNDARY.md.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// UI locale preference for user profile (RU/AZ per TZ).
enum UserLocale {
  AZ
  RU
}

model Organization {
  id                           String                        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                         String
  /// Stage-1 WA0001: encrypted taxId payload for gradual cutover.
  taxIdCipher                  String?                       @map("tax_id_cipher")
  /// Stage-2 WA0001: deterministic blind index (HMAC) for equality search.
  taxIdBlindIndex              String?                       @unique @map("tax_id_blind_index")
  currency                     String                        @default("AZN")
  /// *
  ///    * Юридический адрес (профиль организации, v19.0).
  legalAddress                 String?                       @map("legal_address")
  /// *
  ///    * Контактный телефон организации.
  phone                        String?
  /// *
  ///    * Руководитель (ФИО / должность в свободной форме для печати).
  directorName                 String?                       @map("director_name")
  /// *
  ///    * Логотип (URL в объектном хранилище после upload).
  logoUrl                      String?                       @map("logo_url")
  /// *
  ///    * Метод оценки запасов для COGS: средневзвешенная (AVCO) или FIFO по движениям.
  valuationMethod              InventoryValuationMethod      @default(AVCO) @map("valuation_method")
  settings                     Json                          @default("{}")
  subscriptionPlan             String?                       @map("subscription_plan")
  billingStatus                BillingStatus                 @default(ACTIVE) @map("billing_status")
  createdAt                    DateTime                      @default(now()) @map("created_at")
  updatedAt                    DateTime                      @updatedAt @map("updated_at")
  /// *
  ///    * Секрет URL вебхука Direct Banking: POST /api/public/banking/webhook/:secret
  bankWebhookSecret            String?                       @unique @map("bank_webhook_secret")
  /// *
  ///    * Владелец организации для биллинга (v10.2).
  ownerId                      String?                       @map("owner_id") @db.Uuid
  /// *
  ///    * Включённые модули (slug) на уровне организации — денормализация для биллинга v10.2;
  ///    * источник правды для гейтинга остаётся OrganizationSubscription.customConfig / activeModules.
  activeModules                String[]                      @default([]) @map("active_modules")
  /// *
  ///    * Bytes stored in object storage for this org (logos, PDFs); quota STORAGE (v23.0).
  storageUsedBytes             BigInt                        @default(0) @map("storage_used_bytes")
  /// @deprecated Phase 16 — prepaid WhatsApp packs; use whatsappAlertsUsed + BillingTrustGuard.
  whatsappOutboundMessagesBalance Int                         @default(0) @map("whatsapp_outbound_messages_balance")
  /// @deprecated Legacy post-paid meter — use subscription TariffTier limits.
  currentCreditTier              TariffTier?                   @map("current_credit_tier")
  /// @deprecated Legacy post-paid balance.
  accumulatedBalance             Decimal                       @default(0) @map("accumulated_balance") @db.Decimal(12, 2)
  /// @deprecated Org-level period key — use OrganizationSubscription.billingPeriodKey.
  billingPeriodKey               String?                       @map("billing_period_key") @db.VarChar(7)
  /// @deprecated Use subscription-tier limits + monthly counters in application layer.
  whatsappAlertsUsed             Int                           @default(0) @map("whatsapp_alerts_used")
  ocrPagesUsed                   Int                           @default(0) @map("ocr_pages_used")
  usageMeterEvents               UsageMeterEvent[]
  deletedAt                    DateTime?                     @map("deleted_at") @db.Timestamptz(6)
  holdingId                    String?                       @map("holding_id") @db.Uuid
  /// NAS plan / organization type: commercial, budget (government), or non-commercial (NGO).
  kind                         OrganizationKind              @default(COMMERCIAL) @map("kind")
  /// Legal form selected at onboarding (shared with Counterparty legal forms).
  legalForm                    CounterpartyLegalForm         @default(LLC) @map("legal_form")
  isDeleted                    Boolean                       @default(false) @map("is_deleted")
  /// External client id for Drakaris/yığım aggregator (uppercase alphanumeric).
  drakarisClientId             String?                       @unique @map("drakaris_client_id")
  absenceTypes                 AbsenceType[]
  absences                     Absence[]
  accessRequests               AccessRequest[]
  accountMappings              AccountMapping[]
  accountBalances              AccountBalance[]
  accounts                     Account[]
  advanceReports               AdvanceReport[]
  auditLogs                    AuditLog[]
  bankStatementLines           BankStatementLine[]
  bankStatements               BankStatement[]
  billingInvoiceItems          BillingInvoiceItem[]
  cashDesks                    CashDesk[]
  cashFlowItems                CashFlowItem[]
  cashOrders                   CashOrder[]
  counterparties               Counterparty[]
  departments                  Department[]
  bankAccountsOrg              OrganizationBankAccount[]
  digitalSignatureLogs         DigitalSignatureLog[]
  employees                    Employee[]
  fixedAssetDepreciationMonths FixedAssetDepreciationMonth[]
  fixedAssetMonthlyUsages      FixedAssetMonthlyUsage[]
  fixedAssets                  FixedAsset[]
  inventoryAdjustments         InventoryAdjustment[]
  inventoryAuditLines          InventoryAuditLine[]
  inventoryAudits              InventoryAudit[]
  invoiceItems                 InvoiceItem[]
  paymentAllocations           PaymentAllocation[]
  invoicePayments              InvoicePayment[]
  invoices                     Invoice[]
  journalEntries               JournalEntry[]
  invites                      OrganizationInvite[]
  memberships                  OrganizationMembership[]
  organizationModules          OrganizationModule[]
  organizationBundles          OrganizationBundle[]
  subscription                 OrganizationSubscription?
  holding                      Holding?                      @relation(fields: [holdingId], references: [id])
  owner                        User?                         @relation("OrganizationOwner", fields: [ownerId], references: [id])
  currencyRef                  Currency                      @relation("OrganizationCurrency", fields: [currency], references: [code], onUpdate: Cascade)
  paymentOrders                PaymentOrder[]
  taxDeclarationExports        TaxDeclarationExport[]
  payrollRuns                  PayrollRun[]
  salaryRegistries             SalaryRegistry[]
  bankPaymentDrafts            BankPaymentDraft[]
  ifrsMappingRules             IfrsMappingRule[]
  payrollSlips                 PayrollSlip[]
  integrationSyncRuns          IntegrationSyncRun[]
  ocrJobs                      OcrJob[]
  customsDeclarations          CustomsDeclaration[]
  customsDeclarationItems      CustomsDeclarationItem[]
  productRecipes               ProductRecipe[]
  products                     Product[]
  stockItems                   StockItem[]
  stockMovements               StockMovement[]
  timesheets                   Timesheet[]
  transactions                 Transaction[]
  warehouses                   Warehouse[]
  warehouseBins                WarehouseBin[]
  notifications                Notification[]
  referral                     Referral?
  ownershipDisputes            OwnershipDispute[]
  securityState                OrganizationSecurityState?
  dataSnapshots                OrganizationDataSnapshot[]
  tenantRollbackRecords        TenantRollbackRecord[]
  entityActivities             EntityActivity[]
  entityComments               EntityComment[]
  approvalPolicies             ApprovalPolicy[]
  approvalRequests             ApprovalRequest[]
  prepaidExpenses              PrepaidExpense[]
  psaProjects                  PsaProject[]
  overheadDrivers              OverheadDriver[]
  overheadPools                OverheadPool[]
  manufacturingReleases        ManufacturingRelease[]
  manufacturingOrders          ManufacturingOrder[]
  manufacturingOrderLines      ManufacturingOrderLine[]
  earlyAccessEvents            EarlyAccessEvent[]
  earlyAccessSignups           EarlyAccessSignup[]
  satelliteEventsProcessed     SatelliteEventProcessed[]
  auditSamples                 AuditSample[]
  auditEngagements             AuditEngagement[]
  auditEngagementInvitesTargets AuditEngagementInvite[] @relation("OrgAuditEngagementInvites")
  riskAudits                   RiskAudit[]
  councilVerdicts              CouncilVerdict[]

  @@index([ownerId])
  @@index([holdingId, id])
  @@index([holdingId])
  @@index([kind])
  @@map("organizations")
}

/// Organization type / NAS chart variant (commercial vs budget vs NGO).
enum OrganizationKind {
  COMMERCIAL
  BUDGET
  NGO
}

/// Global NAS template row: `code` is unique per `kind` (same numeric code may differ by kind).
model TemplateAccount {
  id             String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  kind           OrganizationKind   @default(COMMERCIAL) @map("kind")
  code           String             @map("code")
  nameAz         String             @map("name_az")
  nameRu         String             @map("name_ru")
  nameEn         String             @map("name_en")
  accountType    AccountType        @map("account_type")
  parentCode     String?            @map("parent_code")
  cashProfile    String?            @map("cash_profile")
  sortOrder      Int                @default(0) @map("sort_order")
  isDeprecated   Boolean            @default(false) @map("is_deprecated")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  accounts       Account[]

  @@unique([kind, code])
  @@index([kind])
  @@index([code])
  @@map("template_accounts")
}

model AccountBalance {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  accountId      String       @map("account_id") @db.Uuid
  ledgerType     LedgerType   @default(NAS) @map("ledger_type")
  balanceDate    DateTime     @map("balance_date") @db.Date
  debitBalance   Decimal      @default(0) @map("debit_balance") @db.Decimal(19, 4)
  creditBalance  Decimal      @default(0) @map("credit_balance") @db.Decimal(19, 4)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  account        Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, accountId, ledgerType, balanceDate])
  @@index([organizationId, ledgerType, balanceDate])
  @@map("account_balances")
}

/// *
///  * Банковские счета организации (реквизиты для документов и интеграций), 1:N к Organization.
model OrganizationBankAccount {
  id                String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId    String           @map("organization_id") @db.Uuid
  bankName          String           @map("bank_name")
  /// Legacy field (kept for backward compatibility in old integrations/UI).
  accountNumber     String?          @map("account_number")
  currency          String           @default("AZN")
  iban              String
  swift             String?
  ledgerAccountCode String           @map("ledger_account_code")
  accountType       BankAccountType  @default(MAIN) @map("account_type")
  isPrimary         Boolean          @default(false) @map("is_primary")
  isFrozen          Boolean          @default(false) @map("is_frozen")
  isArchived        Boolean          @default(false) @map("is_archived")
  /// FK to system bank branch directory (BankBranch). When set on create/update,
  /// AccountingService auto-generates NAS subaccount 221.<bankCode>.<seq>.
  bankBranchId      String?          @map("bank_branch_id") @db.Uuid
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  organization      Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  currencyRef       Currency         @relation("OrganizationBankAccountCurrency", fields: [currency], references: [code], onUpdate: Cascade)
  bankBranch        BankBranch?      @relation(fields: [bankBranchId], references: [id], onDelete: SetNull)
  salaryRegistries  SalaryRegistry[]
  deletedAt         DateTime?        @map("deleted_at") @db.Timestamptz(6)
  deletedByUserId   String?          @map("deleted_by_user_id") @db.Uuid
  deletedReason     String?          @map("deleted_reason")

  @@unique([organizationId, iban], map: "organization_bank_accounts_org_iban_uidx")
  @@index([organizationId, isArchived, createdAt], map: "organization_bank_accounts_org_arch_created_idx")
  @@index([organizationId, accountType], map: "organization_bank_accounts_org_type_idx")
  @@index([organizationId, ledgerAccountCode], map: "organization_bank_accounts_org_ledger_idx")
  @@index([organizationId, deletedAt], map: "organization_bank_accounts_org_deleted_at_idx")
  @@index([bankBranchId], map: "organization_bank_accounts_bank_branch_idx")
  @@map("organization_bank_accounts")
}

/// *
///  * Системный справочник банков Азербайджана (без `organizationId`, общий для всей платформы).
///  * Двузначный `code` (`01`–`22`) используется в маске NAS-субсчёта `221.<bankCode>.<seq>`.
model BankGlossary {
  id                String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// Официальное наименование банка на азербайджанском (для UI/печати).
  nameAz            String       @map("name_az")
  /// VÖEN банка (10 цифр), уникальный.
  voen              String       @unique
  /// Двузначный код банка в маске субсчёта `221.<code>.<seq>` (фиксирован для платформы).
  code              String       @unique @db.Char(2)
  /// Корреспондентский IBAN банка в ЦБА (одинаков для всех филиалов; см. `prisma/catalog/bank/banks-table.md`).
  correspondentIban String?      @unique @map("correspondent_iban")
  /// SWIFT-код банка (общий для всех филиалов, дублируется в `BankBranch.swift` для UI).
  swift             String?
  /// Контактные телефоны головного офиса.
  headPhones        String[]     @default([]) @map("head_phones")
  /// Юр./фактический адрес головного офиса.
  headAddress       String?      @map("head_address")
  isActive          Boolean      @default(true) @map("is_active")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  branches          BankBranch[]

  @@map("bank_glossary")
}

/// *
///  * Филиал банка из системного справочника. Используется при создании
///  * `OrganizationBankAccount` для автогенерации субсчёта 221.<bankCode>.<seq>.
model BankBranch {
  id                       String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bankId                   String                    @map("bank_id") @db.Uuid
  /// 6-digit MFO code in Azerbaijan banking system (unique within bank).
  branchCode               String                    @map("branch_code")
  name                     String
  swift                    String?
  address                  String?
  /// Контактные телефоны филиала; в исходной таблице импорта поля разделяются через `;`.
  phones                   String[]                  @default([]) @map("phones")
  /// True для записи головного офиса банка (отображение «Baş ofis»).
  isHeadOffice             Boolean                   @default(false) @map("is_head_office")
  isActive                 Boolean                   @default(true) @map("is_active")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  bank                     BankGlossary              @relation(fields: [bankId], references: [id], onDelete: Cascade)
  organizationBankAccounts OrganizationBankAccount[]

  @@unique([bankId, branchCode], map: "bank_branches_bank_branch_code_uidx")
  @@index([bankId], map: "bank_branches_bank_idx")
  @@index([bankId, isHeadOffice], map: "bank_branches_bank_head_office_idx")
  @@map("bank_branches")
}

/// *
///  * Глобальный справочник компаний по VÖEN: асинхронно наполняется из профиля организации и карточек контрагентов (Smart-fill).
model GlobalCompanyDirectory {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  taxId        String   @unique @map("tax_id")
  name         String
  legalForm    CounterpartyLegalForm? @map("legal_form")
  legalAddress String?  @map("legal_address")
  phone        String?  @map("phone")
  directorName String?  @map("director_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("global_company_directory")
}

/// *
///  * Подключённые модули по организации: цена на момент включения и политика отмены (pro-rata / конец периода).
model OrganizationModule {
  organizationId      String       @map("organization_id") @db.Uuid
  moduleKey           String       @map("module_key")
  priceSnapshot       Decimal      @map("price_snapshot") @db.Decimal(12, 2)
  activatedAt         DateTime     @default(now()) @map("activated_at")
  pendingDeactivation Boolean      @default(false) @map("pending_deactivation")
  /// *
  ///    * Заполнено при отключении: автопродление снято, доступ до accessUntil.
  cancelledAt         DateTime?    @map("cancelled_at")
  /// *
  ///    * Конец текущего оплаченного периода (UTC), после — модуль снимается с activeModules.
  accessUntil         DateTime?    @map("access_until") @db.Timestamptz(6)
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([organizationId, moduleKey])
  @@map("organization_modules")
}

/// *
///  * Подключённый пакет модулей (pricing_bundles) по организации; биллинг с дедупликацией пересечений с à la carte.
model OrganizationBundle {
  organizationId      String        @map("organization_id") @db.Uuid
  bundleId            String        @map("bundle_id") @db.Uuid
  priceSnapshot       Decimal       @map("price_snapshot") @db.Decimal(12, 2)
  activatedAt         DateTime      @default(now()) @map("activated_at")
  pendingDeactivation Boolean       @default(false) @map("pending_deactivation")
  cancelledAt         DateTime?     @map("cancelled_at")
  accessUntil         DateTime?     @map("access_until") @db.Timestamptz(6)
  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bundle              PricingBundle @relation(fields: [bundleId], references: [id], onDelete: Restrict)

  @@id([organizationId, bundleId])
  @@map("organization_bundles")
}

/// *
///  * Актуальные цены конструктора: база, модули, квоты (v10.2). Сидируется по умолчанию.
model Pricing {
  id        String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  key       String      @unique
  kind      PricingKind
  name      String
  amountAzn Decimal     @map("amount_azn") @db.Decimal(12, 2)
  /// *
  ///    * Для квот: размер блока (напр. 10 сотрудников, 5 GB, 500 инвойсов); для Foundation/модуля — null.
  unitSize  Int?        @map("unit_size")
  sortOrder Int         @default(0) @map("sort_order")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@map("pricing")
}

/// *
///  * Единый счёт платформы на Owner-аккаунт (TZ §14.8 / v12.3). Не путать с Invoice (продажи).
model SubscriptionInvoice {
  id             String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// *
  ///    * Плательщик / владелец портфеля (owner user).
  userId         String                    @map("user_id") @db.Uuid
  /// *
  ///    * Итог по счёту (AZN).
  amount         Decimal                   @db.Decimal(12, 2)
  status         SubscriptionInvoiceStatus
  /// *
  ///    * Дата выставления / учёта.
  date           DateTime                  @db.Date
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")
  /// *
  ///    * Расчётный период (месяц и т.п.).
  periodStart    DateTime?                 @map("period_start") @db.Timestamptz(6)
  periodEnd      DateTime?                 @map("period_end") @db.Timestamptz(6)
  billingPeriod  String?                   @map("billing_period")
  /// *
  ///    * Готовый PDF в объектном хранилище (опционально).
  pdfLink        String?                   @map("pdf_link")
  /// *
  ///    * Связь с заказом оплаты (шлюз); счёт выставляется на owner, услуга — по organization в строках.
  paymentOrderId String?                   @unique @map("payment_order_id") @db.Uuid
  items          BillingInvoiceItem[]
  paymentOrder   PaymentOrder?             @relation(fields: [paymentOrderId], references: [id])
  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  referralCommissions ReferralCommission[]

  @@index([userId])
  @@index([userId, date])
  @@index([userId, billingPeriod])
  @@map("subscription_invoices")
}

/// *
///  * Строки платформенного счёта: разбивка по организациям (VÖEN) — TZ §14.8.4.
model BillingInvoiceItem {
  id                    String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  subscriptionInvoiceId String              @map("subscription_invoice_id") @db.Uuid
  organizationId        String              @map("organization_id") @db.Uuid
  description           String
  amount                Decimal             @db.Decimal(12, 2)
  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionInvoice   SubscriptionInvoice @relation(fields: [subscriptionInvoiceId], references: [id], onDelete: Cascade)

  @@index([subscriptionInvoiceId])
  @@index([organizationId])
  @@map("billing_invoice_items")
}

/// *
///  * Связь пользователь ↔ организация (роль в рамках организации).
model OrganizationMembership {
  userId          String       @map("user_id") @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  role            UserRole
  joinedAt        DateTime     @default(now()) @map("joined_at")
  deletedAt       DateTime?    @map("deleted_at") @db.Timestamptz(6)
  deletedByUserId String?      @map("deleted_by_user_id") @db.Uuid
  deletedReason   String?      @map("deleted_reason")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, organizationId])
  @@index([organizationId])
  @@index([organizationId, deletedAt], map: "organization_memberships_org_deleted_at_idx")
  @@map("organization_memberships")
}

/// *
///  * Запрос на вступление в организацию (поиск по VÖEN).
model AccessRequest {
  id              String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId  String              @map("organization_id") @db.Uuid
  requesterId     String              @map("requester_id") @db.Uuid
  status          AccessRequestStatus @default(PENDING)
  message         String?
  createdAt       DateTime            @default(now()) @map("created_at")
  decidedAt       DateTime?           @map("decided_at")
  decidedByUserId String?             @map("decided_by_user_id") @db.Uuid
  decidedBy       User?               @relation("AccessRequestDecider", fields: [decidedByUserId], references: [id])
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requester       User                @relation("AccessRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  deletedAt       DateTime?           @map("deleted_at") @db.Timestamptz(6)
  deletedByUserId String?             @map("deleted_by_user_id") @db.Uuid
  deletedReason   String?             @map("deleted_reason")

  @@index([organizationId, status])
  @@index([requesterId])
  @@index([organizationId, deletedAt], map: "access_requests_org_deleted_at_idx")
  @@map("access_requests")
}

/// *
///  * Приглашение по email в организацию.
model OrganizationInvite {
  id              String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  email           String
  role            UserRole
  status          InviteStatus @default(PENDING)
  invitedByUserId String?      @map("invited_by_user_id") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at")
  decidedAt       DateTime?    @map("decided_at")
  invitedBy       User?        @relation("InviteInviter", fields: [invitedByUserId], references: [id])
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deletedAt       DateTime?    @map("deleted_at") @db.Timestamptz(6)
  deletedByUserId String?      @map("deleted_by_user_id") @db.Uuid
  deletedReason   String?      @map("deleted_reason")

  @@index([organizationId, email])
  @@index([organizationId, deletedAt], map: "organization_invites_org_deleted_at_idx")
