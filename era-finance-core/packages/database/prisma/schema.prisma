  responsibleEmployeeId  String?              @map("responsible_employee_id") @db.Uuid
  responsibleEmployee    Employee?            @relation("InventoryAuditResponsible", fields: [responsibleEmployeeId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  notes                  String?              @map("notes")
