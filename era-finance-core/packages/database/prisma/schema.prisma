  riskAudit          RiskAudit?             @relation(fields: [riskAuditId], references: [id], onDelete: SetNull)

  @@unique([organizationId, dedupeKey], map: "council_verdicts_org_dedupe_uidx")
  @@index([organizationId, status], map: "council_verdicts_org_status_idx")
