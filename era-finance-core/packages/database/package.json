{
  "name": "@erafinance/database",
  "version": "0.0.1",
  "private": true,
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./chart-seed": {
      "types": "./dist/lib/chart/chart-seed.d.ts",
      "default": "./dist/lib/chart/chart-seed.js"
    }
  },
  "scripts": {
    "postinstall": "prisma generate && npm run build:chart",
    "build:chart": "tsc -p tsconfig.chart.json",
    "build": "prisma generate && npm run build:chart",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:clear-squash-row": "prisma db execute --file prisma/scripts/ops/delete-squashed-migration-row.sql",
    "db:migrate:reset-public-dev": "prisma db execute --file prisma/scripts/ops/reset-public-schema-dev.sql",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:seed:core": "tsx prisma/seed.ts --layers=core",
    "db:seed:national": "tsx prisma/seed.ts --layers=national",
    "db:seed:hr": "tsx prisma/seed.ts --layers=hr",
    "db:seed:trade": "tsx prisma/seed.ts --layers=trade",
    "db:seed:geo": "tsx prisma/seed.ts --layers=geo",
    "db:seed:bank": "tsx prisma/seed.ts --layers=bank",
    "db:seed:placeholders": "tsx prisma/seed.ts --layers=core --only=system-product-templates",
    "db:audit-currency-codes": "tsx prisma/scripts/ops/audit/audit-currency-codes.ts",
    "db:ifrs-demo-map": "tsx prisma/scripts/ops/ifrs/ifrs-demo-mapping.ts",
    "db:studio": "prisma studio",
    "db:sync-i18n": "tsx prisma/scripts/ops/i18n/sync-translation-overrides-from-resources.ts",
    "db:sync-i18n:prune": "tsx prisma/scripts/ops/i18n/sync-translation-overrides-from-resources.ts --prune",
    "db:audit-i18n-overrides": "tsx prisma/scripts/ops/i18n/audit-translation-overrides.ts",
    "db:audit-i18n-overrides:fix": "tsx prisma/scripts/ops/i18n/audit-translation-overrides.ts --fix",
    "db:seed:tivi": "tsx prisma/scripts/ops/demo/seed-tivi.ts",
    "db:import-banks-md": "tsx prisma/scripts/import-banks-md.ts",
    "db:import-banks-md:dry": "tsx prisma/scripts/import-banks-md.ts --dry-run",
    "db:gen:banks-branches-seed": "tsx prisma/scripts/generate-banks-branches-seed.ts",
    "db:ensure-tax-pro-pricing": "tsx scripts/ensure-tax-pro-pricing.ts",
    "db:ensure-trade-pro-pricing": "tsx scripts/ensure-trade-pro-pricing.ts",
    "db:seed-customs-tariffs": "tsx scripts/seed-customs-tariff-rates.ts",
    "db:parse-az-customs-md": "node scripts/parse-az-customs-act-md.mjs",
    "db:import-customs-tariff-json": "tsx scripts/import-customs-tariff-from-json.ts",
    "db:prod-init": "tsx prisma/scripts/ops/platform/prod-init.ts",
    "db:apply-template:ifrs": "tsx prisma/scripts/ops/ifrs/apply-template-ifrs-mapping.ts",
    "db:migrate:nas-names": "tsx prisma/scripts/ops/nas/data-migrate-nas-account-names.ts",
    "db:migrate:org-tax-cipher": "tsx prisma/scripts/ops/pii/data-migrate-org-tax-id-cipher.ts",
    "db:migrate:pii-stage3": "tsx prisma/scripts/ops/pii/data-migrate-pii-stage3.ts",
    "db:nullify:pii-plaintext:phase1": "tsx prisma/scripts/ops/pii/data-nullify-pii-plaintext-phase1.ts",
    "db:nullify:pii-plaintext:phase2": "tsx prisma/scripts/ops/pii/data-nullify-pii-plaintext-phase2.ts",
    "db:audit:pii-cutover": "tsx prisma/scripts/ops/pii/audit-pii-cutover-readiness.ts",
    "db:audit:pii-plaintext": "tsx prisma/scripts/ops/pii/audit-pii-plaintext-remaining.ts",
    "db:assert:pii-plaintext-zero": "tsx prisma/scripts/ops/pii/assert-pii-plaintext-zero.ts",
    "db:seed:nas-templates": "tsx prisma/scripts/seed-nas-accounts.ts",
    "db:build:nas-json": "tsx prisma/scripts/build-nas-catalog-jsons.ts",
    "docker-init:export": "tsx prisma/docker-init/export-seed-data.ts",
    "docker-init:super-admin-hash": "tsx prisma/docker-init/export-super-admin-hash.ts",
    "db:resync-nas-user": "tsx prisma/scripts/ops/nas/resync-nas-for-user-email.ts",
    "db:seed:verify": "npm run build:chart && npm test",
    "test": "jest --config jest.config.cjs"
  },
  "dependencies": {
    "@prisma/client": "^7.0.0",
    "@prisma/adapter-pg": "^7.0.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.6.1",
    "pg": "^8.16.3",
    "prisma": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0"
  }
}
