# Control plane (era-365-orchestrator)
CONTROL_PLANE_URL=http://127.0.0.1:4100
NEXT_PUBLIC_CONTROL_PLANE_URL=http://127.0.0.1:4100
# CONTROL_PLANE_SERVICE_TOKEN=

# Auth: legacy (Finance JWT) | control-plane (orchestrator JWT)
ERA_AUTH_MODE=legacy
# Proxy RBAC (join-org, access-requests, transfer-ownership) to orchestrator
ERA_CONTROL_PLANE_RBAC_PROXY=true
# Route sales invoice email via orchestrator Notifications Pack (staging: true)
# ERA_NOTIFICATIONS_PACK=true
