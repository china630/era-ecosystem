# .cursorignore — DayDay ERP (NestJS, Next.js, Prisma, Docker monorepo)
# Cursor indexes respect this file; patterns follow .gitignore semantics.

# =============================================================================
# 1. Dependencies
# =============================================================================

node_modules/
**/node_modules/

# =============================================================================
# 2. Build outputs
# =============================================================================

dist/
**/dist/
.next/
**/.next/
out/
**/out/
build/
**/build/

# =============================================================================
# 3. Logs
# =============================================================================

*.log
**/logs/
logs/
npm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================================
# 4. Caches
# =============================================================================

.turbo/
**/.turbo/
.cache/
**/.cache/
.eslintcache
**/.eslintcache
*.tsbuildinfo
**/*.tsbuildinfo

# =============================================================================
# 5. Secrets (never index real env files)
# =============================================================================

.env
.env.*
**/.env
**/.env.*
!.env.example

# =============================================================================
# 6. Database — Prisma migration history (large SQL history; open on demand)
# =============================================================================

#**/prisma/migrations/
#**/prisma/migrations/**

# =============================================================================
# 7. System files
# =============================================================================

.DS_Store
**/Thumbs.db
Thumbs.db

# =============================================================================
# 8. Heavy / non-code context (index noise; attach via @ when needed)
# =============================================================================

/screens/
#/docs/
/package-lock.json
/_ko1_sheet_dump.json
#/TZ.md
#/PRD.md
# DESIGN.md — в индексе (маленький файл): @ и правила для UI

