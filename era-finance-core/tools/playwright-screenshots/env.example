# Скопируйте в корень монорепо как часть .env или задайте переменные в окружении.
# Дополнительно можно положить этот файл как tools/playwright-screenshots/.env — он перекрывает корневой.

# URL фронтенда (Next.js)
E2E_BASE_URL=http://127.0.0.1:3000

# Учётная запись для входа (обязательны именно эти имена ИЛИ синонимы ниже)
E2E_EMAIL=you@example.com
E2E_PASSWORD=your-password
# PLAYWRIGHT_EMAIL= / PLAYWRIGHT_PASSWORD=
# SCREENSHOT_EMAIL= / SCREENSHOT_PASSWORD=

# Язык интерфейса на скриншотах: ru | az (по умолчанию az)
# E2E_LOCALE=az

# Необязательно: выбор организации при нескольких компаниях
E2E_ORG_NAME=
# UUID организации ИЛИ VÖEN (налоговый номер, только цифры) — не путать с внутренним id
E2E_ORG_ID=

# Только один экран (как --only), если не хотите передавать флаги через npm
# E2E_ONLY=03-banking-cash

# Принудительно пройти логин заново (игнорировать session.json)
# E2E_FORCE_LOGIN=1
