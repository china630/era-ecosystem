# Скопируйте в .env в корне репозитория (рядом с docker-compose.prod.yml):
#   cp env.production.example .env && nano .env
#
# Docker Compose подхватывает этот файл для подстановки переменных (в т.ч. COMPOSE_PROJECT_NAME).
#
# Stack targets: Node.js 22 + Prisma ORM 7 (prisma.config.ts + adapter-pg).

# Имя проекта Compose — стабильное имя сети ${COMPOSE_PROJECT_NAME}_default (миграции, отладка).
COMPOSE_PROJECT_NAME=erafinance_prod

# --- Postgres (обязательно задайте надёжный пароль) ---
POSTGRES_USER=erafinance
POSTGRES_DB=erafinance
POSTGRES_PASSWORD=

# --- Redis: только из .env; для сервиса redis из docker-compose.prod.yml ---
REDIS_URL=redis://redis:6379
# Опционально: отдельный logical DB для BullMQ (URL path = номер DB), см. apps/api/src/queue/bullmq.config.ts
# REDIS_URL=redis://redis:6379/2

# --- Опционально: вебхук при падении фоновой BullMQ-задачи (Slack / Telegram Bot API и т.п.) ---
# ERAFINANCE_BULLMQ_ALERT_WEBHOOK_URL=

# --- Tenant snapshots (метаданные): срок жизни записи expiresAt (дней), по умолчанию 30 ---
# SNAPSHOT_RETENTION_DAYS=30

# --- Мониторинг (опционально, см. docs/deploy/monitoring/README.md) ---
# PROMETHEUS_PUBLISH_PORT=9090
# GRAFANA_PUBLISH_PORT=3001
# GF_SECURITY_ADMIN_PASSWORD=

# --- JWT (обязательно уникальные длинные секреты для production) ---
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- Audit log integrity (рекомендуется) ---
# Если не задано, API использует JWT_SECRET (хуже для целостности аудита).
# AUDIT_HASH_SECRET=

# --- Публичный фронт и CORS ---
# Production web-origin должен быть HTTPS (см. TZ.md §1).
# Сюда укажите публичный HTTPS origin (без trailing slash), чтобы API разрешал запросы браузера.
# Пример: CORS_ORIGINS=https://erp.example.com
CORS_ORIGINS=

# Порт web на хосте (контейнер слушает 3000)
PORT=3000
# Порт API на хосте (контейнер слушает API_PORT, по умолчанию 4000)
API_PUBLISH_PORT=4000

# ВАЖНО: NEXT_PUBLIC_* значения вшиваются в клиентский bundle на этапе `docker build` web.
# Для стека docker-compose.prod.yml оставляйте значение по умолчанию (API внутри сети Compose):
NEXT_PUBLIC_API_URL=http://api:4000

# --- Режим обслуживания (опционально, перед миграциями) ---
# В .env для сервиса `web`: `MAINTENANCE_MODE=1` (или true/yes/on) — Next отдаёт HTTP 503 и страницу обслуживания
# для всего трафика, кроме `/_next/*` и favicon. Пересборка образа не нужна; нужен перезапуск web:
#   docker compose -f docker-compose.prod.yml up -d web
# Снять режим: закомментируйте/удалите переменную или поставьте 0 и снова `up -d web`.
# Ограничение: действует только на запросы, которые доходят до контейнера `web`. Если перед ним стоит отдельный
# reverse proxy или открыт прямой порт API — см. `docs/nginx-maintenance.conf`.
# MAINTENANCE_MODE=0

# --- Публичные URL (опционально, но полезно для ссылок/вебхуков) ---
# WEB_APP_PUBLIC_URL=https://erp.example.com
# API_PUBLIC_URL=https://erp.example.com

# --- Опционально: Sentry ---
# SENTRY_DSN_API=
# NEXT_PUBLIC_SENTRY_DSN=

# --- Email (SMTP) (опционально) ---
# Если SMTP_HOST не задан — API не отправляет письма (только логирует).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="ERA Finance <no-reply@example.com>"

# --- Storage (логотипы, PDF) ---
# Production рекомендация: S3-совместимое хранилище.
# STORAGE_DRIVER=s3
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# # Публичная база для файлов (если отличается от endpoint), например CDN:
# # S3_PUBLIC_BASE_URL=https://cdn.example.com/era
#
# Локальный драйвер (если S3 не нужен):
# STORAGE_DRIVER=local
# STORAGE_LOCAL_ROOT=/var/lib/erafinance/storage
#
# Для docker-compose.prod.yml: путь на **хосте**, который монтируется в api как /var/lib/erafinance/storage
# (должен совпадать с STORAGE_LOCAL_ROOT внутри контейнера). По умолчанию тот же путь.
# Перед первым запуском: sudo mkdir -p /var/lib/erafinance/storage && sudo chown 1001:1001 /var/lib/erafinance/storage
# (1001 — uid пользователя nestjs в образе api.)
# ERAFINANCE_STORAGE_HOST_PATH=/var/lib/erafinance/storage

# --- Sentry source maps upload for Web build (опционально) ---
# ВАЖНО: включает upload sourcemaps во время `docker build` web (см. apps/web/Dockerfile).
# SENTRY_UPLOAD_SOURCEMAPS=1
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT_WEB=
# SENTRY_TUNNEL_PATH=

# --- Публикация портов на хост (по желанию смените или закройте файрволом) ---
# POSTGRES_PUBLISH_PORT=5432
# REDIS_PUBLISH_PORT=6379
