NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
# Billing / subscription / referrals / early-access (era-365-orchestrator)
NEXT_PUBLIC_CONTROL_PLANE_URL=http://127.0.0.1:4100
# Stage C — public links (footer on /login, /register, /register-org; /help). Host legal docs outside the repo.
# NEXT_PUBLIC_ERAFINANCE_TERMS_URL=https://example.com/terms
# NEXT_PUBLIC_ERAFINANCE_PRIVACY_URL=https://example.com/privacy
# NEXT_PUBLIC_ERAFINANCE_STATUS_URL=https://status.example.com
# NEXT_PUBLIC_ERAFINANCE_DOCS_URL=https://docs.example.com
# NEXT_PUBLIC_ERAFINANCE_VIDEO_URL=https://www.youtube.com/watch?v=example
# Comma-separated extension IDs for externally_connectable / docs (optional)
# NEXT_PUBLIC_ERAFINANCE_EXT_IDS=dev-extensionId
# Ссылка «Поделиться» портала счёта (должна совпадать с INVOICE_PORTAL_PUBLIC_ORIGIN в API для прод)
# NEXT_PUBLIC_PORTAL_PUBLIC_ORIGIN=http://127.0.0.1:3000
# При запуске `npm run dev:web` из корня репозитория переменные можно задать только в корневом `.env` (см. корневой .env.example).
# Организация определяется из JWT после входа (/login). Заголовок x-organization-id не нужен в web.
#
# Почта: переменные SMTP задаются для API (см. корневой .env.example): SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, SMTP_FROM, SMTP_SECURE.
