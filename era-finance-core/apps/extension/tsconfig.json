{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["chrome", "wxt/client-types"]
  },
  "include": [
    "./entrypoints/**/*.ts",
    "./entrypoints/**/*.tsx",
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./.wxt/**/*.ts"
  ]
}
