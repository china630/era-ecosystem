generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  outlets   Outlet[]
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum ReceiptStatus {
  OPEN
  PAID
  VOID
}

enum ReceiptLineStatus {
  ACTIVE
  VOID
}

model Outlet {
  id        String     @id @default(cuid())
  tenantId  String
  code      String
  name      String
  preset    String?
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  createdAt DateTime   @default(now())
  registers Register[]
  receipts  Receipt[]

  @@unique([tenantId, code])
}

model Register {
  id        String    @id @default(cuid())
  outletId  String
  code      String
  name      String
  outlet    Outlet    @relation(fields: [outletId], references: [id])
  shifts    Shift[]
  receipts  Receipt[]
  createdAt DateTime  @default(now())

  @@unique([outletId, code])
}

model Shift {
  id         String      @id @default(cuid())
  registerId String
  status     ShiftStatus @default(OPEN)
  openedAt   DateTime    @default(now())
  closedAt   DateTime?
  register   Register    @relation(fields: [registerId], references: [id])
  receipts   Receipt[]

  @@index([registerId, status])
}

model Receipt {
  id                String        @id @default(cuid())
  outletId          String
  registerId        String
  shiftId           String
  status            ReceiptStatus @default(OPEN)
  amountNet         Decimal       @default(0) @db.Decimal(12, 2)
  subtotalAmount    Decimal       @default(0) @db.Decimal(12, 2)
  promoCode         String?
  discountPercent   Decimal?      @db.Decimal(5, 2)
  discountAmount    Decimal       @default(0) @db.Decimal(12, 2)
  customerPhone     String?
  loyaltyRef        String?
  fulfillmentType   String?
  pickupSlotKey     String?
  bopisScheduledAt  DateTime?
  paymentMethod     String?
  paidAt            DateTime?
  originalReceiptId String?
  outlet            Outlet        @relation(fields: [outletId], references: [id])
  register          Register      @relation(fields: [registerId], references: [id])
  shift             Shift         @relation(fields: [shiftId], references: [id])
  originalReceipt   Receipt?      @relation("ReceiptReturn", fields: [originalReceiptId], references: [id])
  returnReceipts    Receipt[]     @relation("ReceiptReturn")
  lines             ReceiptLine[]
  createdAt         DateTime      @default(now())

  @@index([shiftId])
  @@index([originalReceiptId])
}

model ReceiptLine {
  id           String            @id @default(cuid())
  receiptId    String
  description  String
  qty          Int               @default(1)
  unitPrice    Decimal           @db.Decimal(12, 2)
  lineTotal    Decimal           @db.Decimal(12, 2)
  plu          String?
  barcode      String?
  isWeighted   Boolean           @default(false)
  weightKg     Decimal?          @db.Decimal(10, 3)
  size         String?
  color        String?
  serial       String?
  batch        String?
  rxRequired   Boolean           @default(false)
  rxApprovedBy String?
  lineStatus   ReceiptLineStatus @default(ACTIVE)
  receipt      Receipt           @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
}

model Role {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  permissionsJson String   @default("[]")
  users           User[]
}

model User {
  id              String    @id @default(cuid())
  login           String    @unique
  email           String?
  fullName        String
  passwordHash    String
  roleId          String
  role            Role      @relation(fields: [roleId], references: [id])
  status          String    @default("ACTIVE")
  isCrossSystem   Boolean   @default(false) @map("is_cross_system")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
}

model ProductCache {
  id          String   @id @default(cuid())
  sku         String   @unique
  barcode     String?
  description String
  unitPrice   Decimal  @db.Decimal(12, 2)
  syncedAt    DateTime @default(now())

  @@index([barcode])
  @@index([sku])
}
